{
  "name": "@kud/ink-ui",
  "version": "0.2.0",
  "description": "React component library for Ink CLIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "ink": ">=7",
    "react": ">=19"
  },
  "dependencies": {
    "cli-spinners": "3.4.0",
    "figures": "6.1.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "ink": "7.1.0",
    "ink-testing-library": "4.0.0",
    "react": "19.2.7",
    "react-devtools-core": "7.0.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "keywords": [
    "ink",
    "cli",
    "react",
    "terminal",
    "ui",
    "components"
  ],
  "license": "MIT",
  "homepage": "https://kud.github.io/ink-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/kud/ink-ui"
  }
}
